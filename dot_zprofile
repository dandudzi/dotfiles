# Homebrew — detect ARM vs Intel
if [[ -f /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# PATH additions
typeset -U path PATH
export BUN_INSTALL="$HOME/.bun"
path=(
    "$HOME/.local/bin"
    "$BUN_INSTALL/bin"
    $path
    "$HOME/Library/Application Support/JetBrains/Toolbox/scripts"
    "/Applications/IntelliJ IDEA CE.app/Contents/MacOS"
    "$HOME/.config/scripts"
)
export PATH

# Fitness tracker LaunchAgents (once per login, not every shell)
CONFIG_HOME="$HOME/.config"
for plist in "$CONFIG_HOME/scripts"/com.fitness-track.*.plist(N); do
    [[ -e "$plist" ]] || continue
    name=$(basename "$plist")
    target="$HOME/Library/LaunchAgents/$name"
    label="${name%.plist}"
    [[ -L "$target" ]] || ln -sf "$plist" "$target"
    launchctl list "$label" &>/dev/null || launchctl bootstrap "gui/$(id -u)" "$target" 2>/dev/null
done
