    match = ["rtk gradle install", "rtk gradlew installDist"],
    not_match = ["rtk gradle test", "rtk ./gradlew build", "rtk ./gradlew publishToMavenLocal"],
)

prefix_rule(
    pattern = ["cargo", "install"],
    decision = "prompt",
    justification = "Cargo package installation can download and install executable code.",
