)

prefix_rule(
    pattern = [["docker", "podman"], "compose", "down", ["-v", "--volumes"]],
    decision = "forbidden",
    justification = "Compose teardown with volume deletion is blocked because it can destroy persistent data.",
    match = ["docker compose down -v", "podman compose down --volumes"],
    not_match = ["docker compose down", "podman compose ps"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["docker", "podman"], "compose", "down", ["-v", "--volumes"]],
    decision = "forbidden",
