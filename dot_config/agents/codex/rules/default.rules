    justification = "Uv run with temporary dependencies through RTK installs packages into its managed cache before execution.",
    match = ["rtk uv run --with pyyaml python script.py"],
    not_match = ["rtk uv run pytest"],
)

prefix_rule(
    pattern = ["poetry", ["install", "add"]],
    decision = "prompt",
    justification = "Poetry package installation operations can download and install third-party code.",
    match = ["poetry install", "poetry add pyyaml"],
    not_match = ["poetry update", "poetry show", "poetry build"],
)

rtk_prefix_rule(
    pattern = ["rtk", "poetry", ["install", "add"]],
    decision = "prompt",
    justification = "Poetry package installation operations through RTK can download and install third-party code.",
    match = ["rtk poetry install", "rtk poetry add pyyaml"],
    not_match = ["rtk poetry update", "rtk poetry show", "rtk poetry build"],
)

prefix_rule(
    pattern = ["pipx", ["install", "inject"]],
    decision = "prompt",
    justification = "Pipx installation operations install executable Python tools outside the project.",
    match = ["pipx install ruff", "pipx inject tool dependency"],
    not_match = ["pipx upgrade-all", "pipx list", "pipx --version"],
)

rtk_prefix_rule(
    pattern = ["rtk", "pipx", ["install", "inject"]],
    decision = "prompt",
    justification = "Pipx installation operations through RTK install executable Python tools outside the project.",
    match = ["rtk pipx install ruff", "rtk pipx inject tool dependency"],
    not_match = ["rtk pipx upgrade-all", "rtk pipx list", "rtk pipx --version"],
)

prefix_rule(
    pattern = [["printenv", "set", "export", "declare"]],
    decision = "prompt",
    justification = "Environment inspection can expose credentials; approve only narrowly scoped variable access.",
    match = ["printenv PATH", "printenv", "set", "export -p", "declare -x"],
    not_match = ["env NO_COLOR=1 command"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["printenv", "set", "export", "declare"]],
    decision = "prompt",
    justification = "Environment inspection through RTK can expose credentials; approve only narrowly scoped access.",
    match = ["rtk printenv PATH", "rtk printenv", "rtk set", "rtk export -p", "rtk declare -x"],
    not_match = ["rtk env NO_COLOR=1 command"],
)


prefix_rule(
    pattern = [["curl", "wget", "ssh", "scp", "sftp", "rsync", "nc", "ncat", "socat", "gh", "glab"]],
    decision = "prompt",
    justification = "Network access, remote execution, and external state changes require approval.",
    match = ["curl https://example.com", "ssh host", "gh pr create"],
    not_match = ["git status"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["curl", "wget", "ssh", "scp", "sftp", "rsync", "nc", "ncat", "socat", "gh", "glab"]],
    decision = "prompt",
    justification = "Network access, remote execution, and external state changes through RTK require approval.",
    match = ["rtk curl https://example.com", "rtk ssh host", "rtk gh pr create"],
    not_match = ["rtk git status"],
)

prefix_rule(
    pattern = [["kill", "pkill", "killall", "systemctl", "service", "launchctl", "crontab", "at", "open", "xdg-open"]],
    decision = "prompt",
    justification = "Process, service, persistence, scheduling, and GUI changes require approval.",
    match = ["kill 123", "systemctl restart app", "crontab -e", "open file.pdf"],
    not_match = ["ps aux"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["kill", "pkill", "killall", "systemctl", "service", "launchctl", "crontab", "at", "open", "xdg-open"]],
    decision = "prompt",
    justification = "Process, service, persistence, scheduling, and GUI changes through RTK require approval.",
    match = ["rtk kill 123", "rtk systemctl restart app", "rtk crontab -e", "rtk open file.pdf"],
    not_match = ["rtk ps aux"],
)

prefix_rule(
    pattern = [["docker", "podman", "colima", "limactl", "vagrant"]],
    decision = "prompt",
    justification = "Container and virtual-machine commands can execute code, mutate state, or access host resources.",
    match = ["docker build .", "podman run image", "colima start"],
    not_match = ["git status"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["docker", "podman", "colima", "limactl", "vagrant"]],
    decision = "prompt",
    justification = "Container and virtual-machine commands through RTK can execute code, mutate state, or access host resources.",
    match = ["rtk docker build .", "rtk podman run image", "rtk colima start"],
    not_match = ["rtk git status"],
)

prefix_rule(
    pattern = [["terraform", "tofu", "pulumi", "kubectl", "helm", "ansible", "ansible-playbook", "packer", "aws", "gcloud", "az", "psql", "mysql", "sqlite3", "redis-cli", "mongosh"]],
    decision = "prompt",
    justification = "Infrastructure, cloud, cluster, and database commands can affect external systems or sensitive data.",
    match = ["terraform plan", "kubectl get pods", "aws sts get-caller-identity", "psql database"],
    not_match = ["git status"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["terraform", "tofu", "pulumi", "kubectl", "helm", "ansible", "ansible-playbook", "packer", "aws", "gcloud", "az", "psql", "mysql", "sqlite3", "redis-cli", "mongosh"]],
    decision = "prompt",
    justification = "Infrastructure, cloud, cluster, and database commands through RTK can affect external systems or sensitive data.",
    match = ["rtk terraform plan", "rtk kubectl get pods", "rtk aws sts get-caller-identity", "rtk psql database"],
    not_match = ["rtk git status"],
)

prefix_rule(
    pattern = [["fdisk", "parted", "diskutil", "zpool", "zfs", "btrfs", "cryptsetup", "lvm", "lvs", "vgs", "pvs"]],
    decision = "prompt",
    justification = "Disk, pool, encryption, and volume tools include both diagnostics and destructive operations; approve exact diagnostic commands only.",
    match = ["diskutil list", "zpool status", "zfs list", "cryptsetup status volume", "lvs"],
    not_match = ["du -sh ."],
)

rtk_prefix_rule(
    pattern = ["rtk", ["fdisk", "parted", "diskutil", "zpool", "zfs", "btrfs", "cryptsetup", "lvm", "lvs", "vgs", "pvs"]],
    decision = "prompt",
    justification = "Disk, pool, encryption, and volume tools through RTK require exact approval for diagnostic use.",
    match = ["rtk diskutil list", "rtk zpool status", "rtk zfs list", "rtk cryptsetup status volume", "rtk lvs"],
    not_match = ["rtk du -sh ."],
)

# Obsidian plugin installation changes vault configuration and can download code.
prefix_rule(
    pattern = ["obsidian", "plugin:install"],
    decision = "prompt",
    justification = "Installing an Obsidian plugin mutates vault state and may download executable code.",
    match = ["obsidian plugin:install example-plugin"],
    not_match = ["obsidian plugin:list", "obsidian plugin:enable example-plugin"],
)

rtk_prefix_rule(
    pattern = ["rtk", "obsidian", "plugin:install"],
    decision = "prompt",
    justification = "Installing an Obsidian plugin through RTK mutates vault state and may download executable code.",
    match = ["rtk obsidian plugin:install example-plugin"],
    not_match = ["rtk obsidian plugin:list", "rtk obsidian plugin:enable example-plugin"],
)

# -----------------------------------------------------------------------------
# FORBIDDEN — agents must not execute these. A human may run them manually.
# -----------------------------------------------------------------------------

prefix_rule(
    pattern = [["sudo", "su", "doas", "pkexec", "visudo"]],
    decision = "forbidden",
    justification = "Privilege escalation is blocked; perform the operation manually with a reviewed command.",
    match = ["sudo rm file", "su root", "doas command", "visudo"],
    not_match = ["whoami"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["sudo", "su", "doas", "pkexec", "visudo"]],
    decision = "forbidden",
    justification = "Privilege escalation through RTK is blocked; perform the operation manually with a reviewed command.",
    match = ["rtk sudo rm file", "rtk su root", "rtk doas command", "rtk visudo"],
    not_match = ["rtk whoami"],
)

prefix_rule(
    pattern = ["rm", ["-rf", "-fr", "-Rf", "-fR"]],
    decision = "forbidden",
    justification = "Forced recursive deletion is blocked; remove reviewed paths individually or perform the operation manually.",
    match = ["rm -rf path", "rm -fr path", "rm -Rf path", "rm -fR path"],
    not_match = ["rm file.txt", "rm -r directory"],
)

rtk_prefix_rule(
    pattern = ["rtk", "rm", ["-rf", "-fr", "-Rf", "-fR"]],
    decision = "forbidden",
    justification = "Forced recursive deletion through RTK is blocked; remove reviewed paths individually or perform the operation manually.",
    match = ["rtk rm -rf path", "rtk rm -fr path", "rtk rm -Rf path", "rtk rm -fR path"],
    not_match = ["rtk rm file.txt", "rtk rm -r directory"],
)

prefix_rule(
    pattern = ["rm", ["-r", "-R", "--recursive"], ["-f", "--force"]],
    decision = "forbidden",
    justification = "Forced recursive deletion is blocked; remove reviewed paths individually or perform the operation manually.",
    match = ["rm -r -f path", "rm -R --force path", "rm --recursive --force path"],
    not_match = ["rm -r directory", "rm --force file.txt"],
)

rtk_prefix_rule(
    pattern = ["rtk", "rm", ["-r", "-R", "--recursive"], ["-f", "--force"]],
    decision = "forbidden",
    justification = "Forced recursive deletion through RTK is blocked; remove reviewed paths individually or perform the operation manually.",
    match = ["rtk rm -r -f path", "rtk rm -R --force path", "rtk rm --recursive --force path"],
    not_match = ["rtk rm -r directory", "rtk rm --force file.txt"],
)

prefix_rule(
    pattern = ["rm", ["-f", "--force"], ["-r", "-R", "--recursive"]],
    decision = "forbidden",
    justification = "Forced recursive deletion is blocked; remove reviewed paths individually or perform the operation manually.",
    match = ["rm -f -r path", "rm --force -R path", "rm --force --recursive path"],
    not_match = ["rm --force file.txt", "rm --recursive directory"],
)

rtk_prefix_rule(
    pattern = ["rtk", "rm", ["-f", "--force"], ["-r", "-R", "--recursive"]],
    decision = "forbidden",
    justification = "Forced recursive deletion through RTK is blocked; remove reviewed paths individually or perform the operation manually.",
    match = ["rtk rm -f -r path", "rtk rm --force -R path", "rtk rm --force --recursive path"],
    not_match = ["rtk rm --force file.txt", "rtk rm --recursive directory"],
)

prefix_rule(
    pattern = ["chmod", ["777", "0777", "a+rwx"]],
    decision = "forbidden",
    justification = "World-writable permissions are blocked; choose the minimum required permission bits.",
    match = ["chmod 777 file", "chmod 0777 file", "chmod a+rwx file"],
    not_match = ["chmod 600 file", "chmod 755 script"],
)

rtk_prefix_rule(
    pattern = ["rtk", "chmod", ["777", "0777", "a+rwx"]],
    decision = "forbidden",
    justification = "World-writable permissions through RTK are blocked; choose the minimum required permission bits.",
    match = ["rtk chmod 777 file", "rtk chmod 0777 file", "rtk chmod a+rwx file"],
    not_match = ["rtk chmod 600 file", "rtk chmod 755 script"],
)

prefix_rule(
    pattern = ["chmod", ["-R", "--recursive"], ["777", "0777", "a+rwx"]],
    decision = "forbidden",
    justification = "Recursive world-writable permissions are blocked; choose scoped paths and minimum permission bits.",
    match = ["chmod -R 777 directory", "chmod --recursive 0777 directory"],
    not_match = ["chmod -R 755 directory"],
)

rtk_prefix_rule(
    pattern = ["rtk", "chmod", ["-R", "--recursive"], ["777", "0777", "a+rwx"]],
    decision = "forbidden",
    justification = "Recursive world-writable permissions through RTK are blocked; choose scoped paths and minimum permission bits.",
    match = ["rtk chmod -R 777 directory", "rtk chmod --recursive 0777 directory"],
    not_match = ["rtk chmod -R 755 directory"],
)

prefix_rule(
    pattern = [["dd", "mkfs", "mkfs.ext2", "mkfs.ext3", "mkfs.ext4", "mkfs.xfs", "mkfs.btrfs", "wipefs", "blkdiscard", "sfdisk", "sgdisk", "newfs", "newfs_apfs", "newfs_hfs", "newfs_msdos", "newfs_exfat", "newfs_udf", "mdadm", "lvremove", "vgremove", "pvremove"]],
    decision = "forbidden",
    justification = "Raw disk, filesystem creation, block discard, RAID, and volume removal are blocked for agents.",
    match = ["dd if=input of=output", "mkfs.ext4 /dev/disk", "blkdiscard /dev/disk", "newfs_apfs /dev/disk", "lvremove volume"],
    not_match = ["diskutil list", "zpool status", "du -sh ."],
)

rtk_prefix_rule(
    pattern = ["rtk", ["dd", "mkfs", "mkfs.ext2", "mkfs.ext3", "mkfs.ext4", "mkfs.xfs", "mkfs.btrfs", "wipefs", "blkdiscard", "sfdisk", "sgdisk", "newfs", "newfs_apfs", "newfs_hfs", "newfs_msdos", "newfs_exfat", "newfs_udf", "mdadm", "lvremove", "vgremove", "pvremove"]],
    decision = "forbidden",
    justification = "Raw disk, filesystem creation, block discard, RAID, and volume removal through RTK are blocked.",
    match = ["rtk dd if=input of=output", "rtk mkfs.ext4 /dev/disk", "rtk blkdiscard /dev/disk", "rtk newfs_apfs /dev/disk", "rtk lvremove volume"],
    not_match = ["rtk diskutil list", "rtk zpool status", "rtk du -sh ."],
)

prefix_rule(
    pattern = ["diskutil", ["eraseDisk", "eraseVolume", "partitionDisk", "zeroDisk", "secureErase", "deleteVolume"]],
    decision = "forbidden",
    justification = "Destructive diskutil operations are blocked; use list or info diagnostics only.",
    match = ["diskutil eraseDisk APFS name disk0", "diskutil eraseVolume APFS disk1s1", "diskutil partitionDisk disk0 GPT APFS name 0b"],
    not_match = ["diskutil list", "diskutil info disk0"],
)

rtk_prefix_rule(
    pattern = ["rtk", "diskutil", ["eraseDisk", "eraseVolume", "partitionDisk", "zeroDisk", "secureErase", "deleteVolume"]],
    decision = "forbidden",
    justification = "Destructive diskutil operations through RTK are blocked; use diagnostics only.",
    match = ["rtk diskutil eraseDisk APFS name disk0", "rtk diskutil eraseVolume APFS disk1s1"],
    not_match = ["rtk diskutil list", "rtk diskutil info disk0"],
)

prefix_rule(
    pattern = ["diskutil", "apfs", ["deleteVolume", "deleteContainer", "eraseVolume", "resizeContainer"]],
    decision = "forbidden",
    justification = "Destructive APFS container and volume operations are blocked for agents.",
    match = ["diskutil apfs deleteVolume disk1s1", "diskutil apfs deleteContainer disk1"],
    not_match = ["diskutil apfs list"],
)

rtk_prefix_rule(
    pattern = ["rtk", "diskutil", "apfs", ["deleteVolume", "deleteContainer", "eraseVolume", "resizeContainer"]],
    decision = "forbidden",
    justification = "Destructive APFS operations through RTK are blocked for agents.",
    match = ["rtk diskutil apfs deleteVolume disk1s1", "rtk diskutil apfs deleteContainer disk1"],
    not_match = ["rtk diskutil apfs list"],
)

prefix_rule(
    pattern = [["zpool", "zfs"], ["destroy", "remove"]],
    decision = "forbidden",
    justification = "Pool and dataset destruction or removal is blocked; use status/list diagnostics only.",
    match = ["zpool destroy pool", "zpool remove pool device", "zfs destroy pool/dataset"],
    not_match = ["zpool status", "zfs list"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["zpool", "zfs"], ["destroy", "remove"]],
    decision = "forbidden",
    justification = "Pool and dataset destruction or removal through RTK is blocked.",
    match = ["rtk zpool destroy pool", "rtk zfs destroy pool/dataset"],
    not_match = ["rtk zpool status", "rtk zfs list"],
)

prefix_rule(
    pattern = ["zfs", "rollback"],
    decision = "forbidden",
    justification = "Dataset rollback can discard changes and is blocked for agents.",
    match = ["zfs rollback pool/dataset@snapshot"],
    not_match = ["zfs list"],
)

rtk_prefix_rule(
    pattern = ["rtk", "zfs", "rollback"],
    decision = "forbidden",
    justification = "Dataset rollback through RTK can discard changes and is blocked.",
    match = ["rtk zfs rollback pool/dataset@snapshot"],
    not_match = ["rtk zfs list"],
)

prefix_rule(
    pattern = ["cryptsetup", ["luksFormat", "erase", "luksErase", "reencrypt"]],
    decision = "forbidden",
    justification = "Destructive encryption-container operations are blocked; use status diagnostics only.",
    match = ["cryptsetup luksFormat /dev/disk", "cryptsetup erase /dev/disk"],
    not_match = ["cryptsetup status volume"],
)

rtk_prefix_rule(
    pattern = ["rtk", "cryptsetup", ["luksFormat", "erase", "luksErase", "reencrypt"]],
    decision = "forbidden",
    justification = "Destructive encryption-container operations through RTK are blocked.",
    match = ["rtk cryptsetup luksFormat /dev/disk", "rtk cryptsetup erase /dev/disk"],
    not_match = ["rtk cryptsetup status volume"],
)

prefix_rule(
    pattern = ["parted", ["mklabel", "mkpart", "rm", "resizepart"]],
    decision = "forbidden",
    justification = "Partition-table mutation is blocked; use print diagnostics only.",
    match = ["parted mklabel gpt", "parted rm 1"],
    not_match = ["parted print"],
)

rtk_prefix_rule(
    pattern = ["rtk", "parted", ["mklabel", "mkpart", "rm", "resizepart"]],
    decision = "forbidden",
    justification = "Partition-table mutation through RTK is blocked.",
    match = ["rtk parted mklabel gpt", "rtk parted rm 1"],
    not_match = ["rtk parted print"],
)

prefix_rule(
    pattern = ["btrfs", "subvolume", "delete"],
    decision = "forbidden",
    justification = "Btrfs subvolume deletion is blocked for agents.",
    match = ["btrfs subvolume delete path"],
    not_match = ["btrfs subvolume list path"],
)

rtk_prefix_rule(
    pattern = ["rtk", "btrfs", "subvolume", "delete"],
    decision = "forbidden",
    justification = "Btrfs subvolume deletion through RTK is blocked for agents.",
    match = ["rtk btrfs subvolume delete path"],
    not_match = ["rtk btrfs subvolume list path"],
)

prefix_rule(
    pattern = ["git", ["prune", "filter-branch", "filter-repo"]],
    decision = "forbidden",
    justification = "Irreversible Git pruning and history rewriting are blocked; use non-destructive inspection or a reviewed manual workflow.",
    match = ["git prune", "git filter-branch -- --all", "git filter-repo --force"],
    not_match = ["git clean -n", "git reset HEAD file", "git gc"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", ["prune", "filter-branch", "filter-repo"]],
    decision = "forbidden",
    justification = "Irreversible Git pruning and history rewriting through RTK are blocked.",
    match = ["rtk git prune", "rtk git filter-branch -- --all", "rtk git filter-repo --force"],
    not_match = ["rtk git clean -n", "rtk git reset HEAD file", "rtk git gc"],
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Hard reset discards working-tree and index changes; use a scoped restore or perform it manually.",
    match = ["git reset --hard", "git reset --hard HEAD~1"],
    not_match = ["git reset HEAD file", "git reset --soft HEAD~1"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Hard reset through RTK discards working-tree and index changes and is blocked.",
    match = ["rtk git reset --hard", "rtk git reset --hard HEAD~1"],
    not_match = ["rtk git reset HEAD file", "rtk git reset --soft HEAD~1"],
)

prefix_rule(
    pattern = ["git", "clean", ["-f", "--force", "-fd", "-df", "-fdx", "-fxd", "-dfx", "-xdf", "-xfd", "-dxf", "-fX", "-fdX"]],
    decision = "forbidden",
    justification = "Forced Git clean permanently deletes untracked files; use dry-run or interactive mode.",
    match = ["git clean -f", "git clean -fdx", "git clean --force"],
    not_match = ["git clean -n", "git clean -i"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", "clean", ["-f", "--force", "-fd", "-df", "-fdx", "-fxd", "-dfx", "-xdf", "-xfd", "-dxf", "-fX", "-fdX"]],
    decision = "forbidden",
    justification = "Forced Git clean through RTK permanently deletes untracked files and is blocked.",
    match = ["rtk git clean -f", "rtk git clean -fdx", "rtk git clean --force"],
    not_match = ["rtk git clean -n", "rtk git clean -i"],
)

prefix_rule(
    pattern = ["git", "gc", "--prune=now"],
    decision = "forbidden",
    justification = "Immediate Git object pruning can remove recovery data; use normal maintenance or run it manually.",
    match = ["git gc --prune=now"],
    not_match = ["git gc", "git gc --auto"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", "gc", "--prune=now"],
    decision = "forbidden",
    justification = "Immediate Git object pruning through RTK can remove recovery data and is blocked.",
    match = ["rtk git gc --prune=now"],
    not_match = ["rtk git gc", "rtk git gc --auto"],
)

prefix_rule(
    pattern = ["git", "stash", ["clear", "drop"]],
    decision = "forbidden",
    justification = "Deleting stashes removes recovery state and is blocked for agents.",
    match = ["git stash clear", "git stash drop stash@{0}"],
    not_match = ["git stash list", "git stash push"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", "stash", ["clear", "drop"]],
    decision = "forbidden",
    justification = "Deleting stashes through RTK removes recovery state and is blocked.",
    match = ["rtk git stash clear", "rtk git stash drop stash@{0}"],
    not_match = ["rtk git stash list", "rtk git stash push"],
)

prefix_rule(
    pattern = ["git", "branch", "-D"],
    decision = "forbidden",
    justification = "Forced branch deletion is blocked; use a reviewed normal deletion or perform it manually.",
    match = ["git branch -D feature"],
    not_match = ["git branch -d feature", "git branch --list"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", "branch", "-D"],
    decision = "forbidden",
    justification = "Forced branch deletion through RTK is blocked.",
    match = ["rtk git branch -D feature"],
    not_match = ["rtk git branch -d feature", "rtk git branch --list"],
)

prefix_rule(
    pattern = ["git", "tag", "-d"],
    decision = "forbidden",
    justification = "Tag deletion is blocked for agents; perform it manually after review.",
    match = ["git tag -d release"],
    not_match = ["git tag --list"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", "tag", "-d"],
    decision = "forbidden",
    justification = "Tag deletion through RTK is blocked for agents.",
    match = ["rtk git tag -d release"],
    not_match = ["rtk git tag --list"],
)

prefix_rule(
    pattern = ["git", "update-ref", "-d"],
    decision = "forbidden",
    justification = "Direct reference deletion is blocked for agents.",
    match = ["git update-ref -d refs/heads/feature"],
    not_match = ["git update-ref refs/heads/feature commit"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", "update-ref", "-d"],
    decision = "forbidden",
    justification = "Direct reference deletion through RTK is blocked for agents.",
    match = ["rtk git update-ref -d refs/heads/feature"],
    not_match = ["rtk git update-ref refs/heads/feature commit"],
)

prefix_rule(
    pattern = ["git", "commit", ["--no-verify", "--no-gpg-sign"]],
    decision = "forbidden",
    justification = "Bypassing commit hooks or signature policy is blocked; use a normal reviewed commit.",
    match = ["git commit --no-verify -m change", "git commit --no-gpg-sign -m change"],
    not_match = ["git commit -m change"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", "commit", ["--no-verify", "--no-gpg-sign"]],
    decision = "forbidden",
    justification = "Bypassing commit hooks or signature policy through RTK is blocked; use a normal reviewed commit.",
    match = ["rtk git commit --no-verify -m change", "rtk git commit --no-gpg-sign -m change"],
    not_match = ["rtk git commit -m change"],
)

prefix_rule(
    pattern = ["git", "reflog", ["drop", "expire", "delete"]],
    decision = "forbidden",
    justification = "Deleting recovery history is blocked for agents.",
    match = ["git reflog drop --all", "git reflog expire --expire=all --all", "git reflog delete HEAD@{1}"],
    not_match = ["git reflog show"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", "reflog", ["drop", "expire", "delete"]],
    decision = "forbidden",
    justification = "Deleting recovery history through RTK is blocked for agents.",
    match = ["rtk git reflog drop --all", "rtk git reflog expire --expire=all --all", "rtk git reflog delete HEAD@{1}"],
    not_match = ["rtk git reflog show"],
)

prefix_rule(
    pattern = ["git", "push", ["--force", "-f", "--force-with-lease", "--force-if-includes", "--mirror", "--delete", "--prune"]],
    decision = "forbidden",
    justification = "Direct forced, mirrored, or deleting pushes are blocked; use a normal reviewed push or perform it manually.",
    match = ["git push --force origin main", "git push --force-with-lease origin main", "git push --force-if-includes origin main", "git push --mirror", "git push --delete origin branch", "git push --prune origin"],
    not_match = ["git push origin main"],
)

# Codex prefix rules cannot match a dangerous flag in every possible argument
# position. Reordered push flags still match the general `git push` prompt rule.
# A full-command hook is required if those forms must be unconditionally denied.

rtk_prefix_rule(
    pattern = ["rtk", "git", "push", ["--force", "-f", "--force-with-lease", "--force-if-includes", "--mirror", "--delete", "--prune"]],
    decision = "forbidden",
    justification = "Direct forced, mirrored, or deleting pushes through RTK are blocked; use a normal reviewed push or perform it manually.",
    match = ["rtk git push --force origin main", "rtk git push --force-with-lease origin main", "rtk git push --force-if-includes origin main", "rtk git push --mirror", "rtk git push --delete origin branch", "rtk git push --prune origin"],
    not_match = ["rtk git push origin main"],
)

