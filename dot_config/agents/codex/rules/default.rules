# Codex execution policy — active user policy.
#
# Audited against Codex CLI 0.144.1 on 2026-07-11. The live
# ~/.codex/rules/default.rules path is intentionally a symlink to this shared
# file so Codex, Claude Code, and OpenCode policy work can retain one reviewed
# source of intent where their native rule formats permit it.
#
# Official documentation still describes the preview `codex execpolicy check`
# tester. The packaged 0.144.1 CLI does not expose that subcommand, so the
# policy's inline `match`/`not_match` tests and a clean fresh-session load are
# the available validation gates until the preview tester ships in the binary.
# Codex uses the strictest decision across all matching prefixes:
# forbidden > prompt > allow.
#
# Native execpolicy rules match token prefixes, not arbitrary flags or
# canonicalized paths. Commands that require path-aware or flag-order-aware
# checks remain prompt/forbidden instead of receiving broad allow rules.
#
# These native rules intentionally accept some spelling gaps, including stacked
# RTK modifiers, reordered flags, and combined option/value tokens. They are a
# strong escalation policy, not an unconditional security boundary for every
# possible command spelling.
#
# The duplicate `rtk` forms are required by the global AGENTS.md instruction
# that all shell commands run through RTK.

# Restrict basename fallback for unconditionally allowed executables. Without
# these declarations, an arbitrary absolute executable such as /tmp/ls could
# inherit the `ls` allow rule when host-executable resolution is enabled.
host_executable(name = "rtk", paths = ["/opt/homebrew/bin/rtk"])
host_executable(name = "ls", paths = ["/bin/ls"])
host_executable(name = "pwd", paths = ["/bin/pwd"])
host_executable(name = "id", paths = ["/usr/bin/id"])
host_executable(name = "whoami", paths = ["/usr/bin/whoami"])
host_executable(name = "uname", paths = ["/usr/bin/uname"])
host_executable(name = "which", paths = ["/usr/bin/which"])
host_executable(name = "true", paths = ["/usr/bin/true"])
host_executable(name = "false", paths = ["/usr/bin/false"])
host_executable(name = "basename", paths = ["/usr/bin/basename"])
host_executable(name = "dirname", paths = ["/usr/bin/dirname"])
host_executable(name = "codex", paths = ["/opt/homebrew/bin/codex"])

# RTK accepts documented global modifiers and transparent command wrappers.
# Mirror every RTK rule across those spellings so the underlying command keeps
# the canonical rule's decision instead of the wrapper receiving a blanket
# decision. Stacked modifiers, `run -c`, and reordered combinations remain
# outside this native prefix coverage.
RTK_SINGLE_MODIFIERS = [
    "--skip-env",
    "--ultra-compact",
    "--verbose",
    "-v",
    "-vv",
    "-vvv",
]

RTK_COMMAND_WRAPPERS = [
    "run",
    "proxy",
    "err",
    "test",
    "summary",
]

RTK_WRAPPER_MODIFIERS = [
    "--skip-env",
    "--ultra-compact",
]

def _rtk_single_modifier_examples(examples):
    expanded = []
    for example in examples:
        for modifier in RTK_SINGLE_MODIFIERS:
            expanded.append("rtk " + modifier + example[3:])
    return expanded

def _rtk_wrapper_examples(examples):
    expanded = []
    for example in examples:
        for wrapper in RTK_COMMAND_WRAPPERS:
            expanded.append("rtk " + wrapper + example[3:])
    return expanded

def _rtk_modifier_wrapper_examples(examples):
    expanded = []
    for example in examples:
        for modifier in RTK_SINGLE_MODIFIERS:
            for wrapper in RTK_COMMAND_WRAPPERS:
                expanded.append("rtk " + modifier + " " + wrapper + example[3:])
    return expanded

def _rtk_wrapper_modifier_examples(examples):
    expanded = []
    for example in examples:
        for wrapper in RTK_COMMAND_WRAPPERS:
            for modifier in RTK_WRAPPER_MODIFIERS:
                expanded.append("rtk " + wrapper + " " + modifier + example[3:])
    return expanded

def rtk_prefix_rule(pattern, decision, justification, match = [], not_match = []):
    prefix_rule(
        pattern = pattern,
        decision = decision,
        justification = justification,
        match = match,
        not_match = not_match,
    )
    prefix_rule(
        pattern = ["rtk", RTK_SINGLE_MODIFIERS] + pattern[1:],
        decision = decision,
        justification = justification,
        match = _rtk_single_modifier_examples(match),
        not_match = _rtk_single_modifier_examples(not_match),
    )
    prefix_rule(
        pattern = ["rtk", RTK_COMMAND_WRAPPERS] + pattern[1:],
        decision = decision,
        justification = justification,
        match = _rtk_wrapper_examples(match),
        not_match = _rtk_wrapper_examples(not_match),
    )
    prefix_rule(
        pattern = ["rtk", RTK_SINGLE_MODIFIERS, RTK_COMMAND_WRAPPERS] + pattern[1:],
        decision = decision,
        justification = justification,
        match = _rtk_modifier_wrapper_examples(match),
        not_match = _rtk_modifier_wrapper_examples(not_match),
    )
    prefix_rule(
        pattern = ["rtk", RTK_COMMAND_WRAPPERS, RTK_WRAPPER_MODIFIERS] + pattern[1:],
        decision = decision,
        justification = justification,
        match = _rtk_wrapper_modifier_examples(match),
        not_match = _rtk_wrapper_modifier_examples(not_match),
    )

# -----------------------------------------------------------------------------
# ALLOW — narrow, read-only commands whose remaining arguments cannot perform
# writes, network calls, child execution, or privilege changes.
# -----------------------------------------------------------------------------

prefix_rule(
    pattern = ["pwd"],
    decision = "allow",
    justification = "Print the current working directory.",
    match = ["pwd", "pwd -L"],
)

rtk_prefix_rule(
    pattern = ["rtk", "pwd"],
    decision = "allow",
    justification = "Print the current working directory through RTK.",
    match = ["rtk pwd", "rtk pwd -L"],
)

prefix_rule(
    pattern = ["ls"],
    decision = "allow",
    justification = "List directory entries without modifying them.",
    match = ["ls", "ls -la"],
    not_match = ["lsof"],
)

rtk_prefix_rule(
    pattern = ["rtk", "ls"],
    decision = "allow",
    justification = "List directory entries through RTK without modifying them.",
    match = ["rtk ls", "rtk ls -la"],
    not_match = ["rtk lsof"],
)

prefix_rule(
    pattern = [["id", "whoami", "uname", "which"]],
    decision = "allow",
    justification = "Inspect local identity, platform, or executable resolution.",
    match = ["id", "whoami", "uname -a", "which git"],
    not_match = ["who"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["id", "whoami", "uname", "which"]],
    decision = "allow",
    justification = "Inspect local identity, platform, or executable resolution through RTK.",
    match = ["rtk id", "rtk whoami", "rtk uname -a", "rtk which git"],
    not_match = ["rtk who"],
)

prefix_rule(
    pattern = [["true", "false", "basename", "dirname"]],
    decision = "allow",
    justification = "Run an inert result command or perform lexical path formatting.",
    match = ["true", "false", "basename path/file", "dirname path/file"],
    not_match = ["date", "arch"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["true", "false", "basename", "dirname"]],
    decision = "allow",
    justification = "Run an inert result command or lexical path formatting through RTK.",
    match = ["rtk true", "rtk false", "rtk basename path/file", "rtk dirname path/file"],
    not_match = ["rtk date", "rtk arch"],
)

prefix_rule(
    pattern = ["codex", ["--version", "-V", "--help", "-h"]],
    decision = "allow",
    justification = "Inspect the installed Codex CLI without starting an agent.",
    match = ["codex --version", "codex --help"],
    not_match = ["codex exec task", "codex resume"],
)

prefix_rule(
    pattern = ["codex", "help"],
    decision = "allow",
    justification = "Inspect Codex CLI help without starting an agent.",
    match = ["codex help", "codex help execpolicy"],
    not_match = ["codex exec task"],
)

prefix_rule(
    pattern = ["codex", "execpolicy", "check"],
    decision = "allow",
    justification = "Run the official preview execution-policy tester when the installed Codex binary provides it.",
    match = ["codex execpolicy check --rules default.rules -- git status"],
    not_match = ["codex exec task"],
)

rtk_prefix_rule(
    pattern = ["rtk", "codex", ["--version", "-V", "--help", "-h"]],
    decision = "allow",
    justification = "Inspect the installed Codex CLI through RTK without starting an agent.",
    match = ["rtk codex --version", "rtk codex --help"],
    not_match = ["rtk codex exec task", "rtk codex resume"],
)

rtk_prefix_rule(
    pattern = ["rtk", "codex", "help"],
    decision = "allow",
    justification = "Inspect Codex CLI help through RTK without starting an agent.",
    match = ["rtk codex help", "rtk codex help execpolicy"],
    not_match = ["rtk codex exec task"],
)

rtk_prefix_rule(
    pattern = ["rtk", "codex", "execpolicy", "check"],
    decision = "allow",
    justification = "Run the official preview execution-policy tester through RTK when the installed Codex binary provides it.",
    match = ["rtk codex execpolicy check --rules default.rules -- git status"],
    not_match = ["rtk codex exec task"],
)

# -----------------------------------------------------------------------------
# PROMPT — potentially modifying, networked, executable, sensitive, or external
# operations. Approval should be granted for the exact invocation only.
#
# Commands outside the explicit classes below remain governed by Codex's
# sandbox and only require escalation when they cross its boundaries. Broad
# allows are avoided because tools such as find, sed, awk, and rg have
# executable or mutating modes.
# -----------------------------------------------------------------------------

prefix_rule(
    pattern = [["mkdir", "touch", "cp", "mv", "ln", "rm", "rmdir", "truncate", "install", "chmod", "chown", "chgrp", "tee", "patch"]],
    decision = "prompt",
    justification = "Filesystem mutation requires approval for the exact paths.",
    match = ["mkdir build", "cp source target", "rm file.txt", "chmod 600 file"],
    not_match = ["pwd"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["mkdir", "touch", "cp", "mv", "ln", "rm", "rmdir", "truncate", "install", "chmod", "chown", "chgrp", "tee", "patch"]],
    decision = "prompt",
    justification = "Filesystem mutation through RTK requires approval for the exact paths.",
    match = ["rtk mkdir build", "rtk cp source target", "rtk rm file.txt", "rtk chmod 600 file"],
    not_match = ["rtk pwd"],
)

# Chezmoi uses `add` both to update existing managed targets and to begin
# managing new targets. Before invoking this command, verify every exact target
# with `rtk chezmoi source-path <target>`. Managed targets may be re-added.
# If any target is not managed, stop and obtain explicit human authorization.
prefix_rule(
    pattern = ["chezmoi", "add"],
    decision = "prompt",
    justification = "Chezmoi add may auto-commit and auto-push. Approve a managed re-add after every exact target has been verified with chezmoi source-path. Reject new or unmanaged targets unless the user explicitly authorized those exact paths.",
    match = [
        "chezmoi add /Users/daniel/.config/agents/codex/rules/default.rules",
    ],
    not_match = [
        "chezmoi status /Users/daniel/.config/agents/codex/rules/default.rules",
        "chezmoi diff /Users/daniel/.config/agents/codex/rules/default.rules",
        "chezmoi apply /Users/daniel/.config/agents/codex/rules/default.rules",
    ],
)

rtk_prefix_rule(
    pattern = ["rtk", "chezmoi", "add"],
    decision = "prompt",
    justification = "Chezmoi add may auto-commit and auto-push. Approve a managed re-add after every exact target has been verified with chezmoi source-path. Reject new or unmanaged targets unless the user explicitly authorized those exact paths.",
    match = [
        "rtk chezmoi add /Users/daniel/.config/agents/codex/rules/default.rules",
    ],
    not_match = [
        "rtk chezmoi status /Users/daniel/.config/agents/codex/rules/default.rules",
        "rtk chezmoi diff /Users/daniel/.config/agents/codex/rules/default.rules",
        "rtk chezmoi apply /Users/daniel/.config/agents/codex/rules/default.rules",
    ],
)

prefix_rule(
    pattern = ["git", ["status", "rev-parse", "ls-files", "add", "commit", "restore", "checkout", "switch", "stash", "merge", "rebase", "cherry-pick", "revert", "branch", "tag", "worktree", "submodule", "config", "remote", "fetch", "pull", "clone", "push", "reset", "clean", "gc", "reflog", "update-ref"]],
    decision = "prompt",
    justification = "Git mutations, network operations, configurable helpers, and content inspection require approval.",
    match = ["git status", "git add file", "git commit -m change", "git push origin main", "git reset HEAD file", "git clean -n"],
    not_match = ["git diff"],
)

rtk_prefix_rule(
    pattern = ["rtk", "git", ["status", "rev-parse", "ls-files", "add", "commit", "restore", "checkout", "switch", "stash", "merge", "rebase", "cherry-pick", "revert", "branch", "tag", "worktree", "submodule", "config", "remote", "fetch", "pull", "clone", "push", "reset", "clean", "gc", "reflog", "update-ref"]],
    decision = "prompt",
    justification = "Git mutations, network operations, configurable helpers, and content inspection through RTK require approval.",
    match = ["rtk git status", "rtk git add file", "rtk git commit -m change", "rtk git push origin main", "rtk git reset HEAD file", "rtk git clean -n"],
    not_match = ["rtk git diff"],
)

prefix_rule(
    pattern = [["bash", "sh", "zsh", "python", "python3", "node", "ruby", "perl", "osascript", "pwsh", "powershell", "tclsh", "lua", "php", "java", "jshell", "R", "Rscript", "deno", "swift"]],
    decision = "prompt",
    justification = "Shells and interpreters can execute arbitrary code.",
    match = ["bash -c 'echo ok'", "python3 script.py", "node -e 'console.log(1)'", "deno run script.ts", "java Main"],
    not_match = ["uname -a"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["bash", "sh", "zsh", "python", "python3", "node", "ruby", "perl", "osascript", "pwsh", "powershell", "tclsh", "lua", "php", "java", "jshell", "R", "Rscript", "deno", "swift"]],
    decision = "prompt",
    justification = "Shells and interpreters executed through RTK can run arbitrary code.",
    match = ["rtk bash -c 'echo ok'", "rtk python3 script.py", "rtk node -e 'console.log(1)'", "rtk deno run script.ts", "rtk java Main"],
    not_match = ["rtk uname -a"],
)

prefix_rule(
    pattern = [["env", "command", "xargs", "parallel", "timeout", "nohup", "nice", "watch", "script", "expect"]],
    decision = "prompt",
    justification = "Execution wrappers can hide or transform a nested command and require exact approval.",
    match = ["env command", "xargs rm", "parallel command", "timeout 10 command", "expect script.exp"],
    not_match = ["pwd"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["env", "command", "xargs", "parallel", "timeout", "nohup", "nice", "watch", "script", "expect", "read"]],
    decision = "prompt",
    justification = "Execution wrappers and RTK content readers require exact approval.",
    match = ["rtk env command", "rtk xargs rm", "rtk timeout 10 command", "rtk read README.md"],
    not_match = ["rtk pwd"],
)

# Headless Neovim loads the full editor configuration and plugins unless the
# approved invocation explicitly limits them, so review each run before launch.
prefix_rule(
    pattern = ["nvim", "--headless"],
    decision = "prompt",
    justification = "Headless Neovim can load plugins or leave runaway background processes; approve the exact invocation.",
    match = ["nvim --headless", "nvim --headless -u NONE +qa"],
    not_match = ["nvim file.lua", "nvim --clean", "nvim file.lua --headless"],
)

rtk_prefix_rule(
    pattern = ["rtk", "nvim", "--headless"],
    decision = "prompt",
    justification = "Headless Neovim through RTK can load plugins or leave runaway background processes; approve the exact invocation.",
    match = ["rtk nvim --headless", "rtk nvim --headless -u NONE +qa"],
    not_match = ["rtk nvim file.lua", "rtk nvim --clean", "rtk nvim file.lua --headless"],
)

prefix_rule(
    pattern = [["cmake", "ninja", "meson"]],
    decision = "prompt",
    justification = "Build-system frontends can execute project or third-party code.",
    match = ["cmake --build build", "ninja test", "meson compile -C build"],
    not_match = ["git status"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["cmake", "ninja", "meson"]],
    decision = "prompt",
    justification = "Build-system frontends through RTK can execute project or third-party code.",
    match = ["rtk cmake --build build", "rtk ninja test", "rtk meson compile -C build"],
    not_match = ["rtk git status"],
)

# Package and toolchain installation operations are explicit even when they
# would otherwise fit inside the sandbox. Upgrade/update and routine list,
# info, build, and test operations are intentionally excluded. Existing
# forbidden publish/deploy rules remain stricter than these prompts.
prefix_rule(
    pattern = ["brew", ["install", "reinstall", "bundle"]],
    decision = "prompt",
    justification = "Homebrew installation operations can download executable code and change machine-level state.",
    match = ["brew install ripgrep", "brew reinstall python", "brew bundle"],
    not_match = ["brew upgrade", "brew list", "brew info ripgrep"],
)

rtk_prefix_rule(
    pattern = ["rtk", "brew", ["install", "reinstall", "bundle"]],
    decision = "prompt",
    justification = "Homebrew installation operations through RTK can download executable code and change machine-level state.",
    match = ["rtk brew install ripgrep", "rtk brew reinstall python", "rtk brew bundle"],
    not_match = ["rtk brew upgrade", "rtk brew list", "rtk brew info ripgrep"],
)

prefix_rule(
    pattern = ["mise", "install"],
    decision = "prompt",
    justification = "Mise installation can download executable toolchains.",
    match = ["mise install node@lts"],
    not_match = ["mise use --global python@3.14", "mise upgrade", "mise ls"],
)

rtk_prefix_rule(
    pattern = ["rtk", "mise", "install"],
    decision = "prompt",
    justification = "Mise installation through RTK can download executable toolchains.",
    match = ["rtk mise install node@lts"],
    not_match = ["rtk mise use --global python@3.14", "rtk mise upgrade", "rtk mise ls"],
)

prefix_rule(
    pattern = [["mvn", "mvnw", "./mvnw"], "install"],
    decision = "prompt",
    justification = "Maven install writes build artifacts and dependencies to the local package repository.",
    match = ["mvn install", "mvnw install", "./mvnw install"],
    not_match = ["mvn test", "./mvnw package"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["mvn", "mvnw", "./mvnw"], "install"],
    decision = "prompt",
    justification = "Maven install through RTK writes build artifacts and dependencies to the local package repository.",
    match = ["rtk mvn install", "rtk mvnw install", "rtk ./mvnw install"],
    not_match = ["rtk mvn test", "rtk ./mvnw package"],
)

prefix_rule(
    pattern = [["gradle", "gradlew", "./gradlew"], ["install", "installDist"]],
