    pattern = ["rtk", "docker", ["system", "builder", "image", "container", "network", "volume"], "prune"],
    decision = "forbidden",
    justification = "Broad Docker pruning through RTK is blocked for agents.",
    match = ["rtk docker system prune", "rtk docker builder prune", "rtk docker image prune", "rtk docker container prune", "rtk docker network prune", "rtk docker volume prune"],
    not_match = ["rtk docker system df", "rtk docker volume ls", "rtk docker image ls"],
)

prefix_rule(
    pattern = [["docker", "podman"], "volume", ["rm", "remove"]],
    decision = "forbidden",
    justification = "Container volume deletion can destroy persistent data and is blocked.",
    match = ["docker volume rm data", "podman volume rm data"],
    not_match = ["docker volume ls", "podman volume inspect data"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["docker", "podman"], "volume", ["rm", "remove"]],
    decision = "forbidden",
    justification = "Container volume deletion through RTK is blocked.",
    match = ["rtk docker volume rm data", "rtk podman volume rm data"],
    not_match = ["rtk docker volume ls", "rtk podman volume inspect data"],
)

