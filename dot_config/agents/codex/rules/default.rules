    match = ["rtk docker compose down -v", "rtk podman compose down --volumes"],
    not_match = ["rtk docker compose down", "rtk podman compose ps"],
)

prefix_rule(
    pattern = [["shutdown", "reboot", "halt", "poweroff", "setenforce", "csrutil"]],
    decision = "forbidden",
    justification = "Power and operating-system security-state changes are blocked for agents.",
    match = ["shutdown -h now", "reboot", "setenforce 0", "csrutil disable"],
    not_match = ["uname -a"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["shutdown", "reboot", "halt", "poweroff", "setenforce", "csrutil"]],
    decision = "forbidden",
    justification = "Power and operating-system security-state changes through RTK are blocked for agents.",
    match = ["rtk shutdown -h now", "rtk reboot", "rtk setenforce 0", "rtk csrutil disable"],
    not_match = ["rtk uname -a"],
)

prefix_rule(
    pattern = [["eval", "yes", "stress", "stress-ng"]],
    decision = "forbidden",
    justification = "Dynamic evaluation and unbounded resource-generation commands are blocked for agents.",
    match = ["eval command", "yes", "stress --cpu 8"],
    not_match = ["echo yes"],
)

rtk_prefix_rule(
    pattern = ["rtk", ["eval", "yes", "stress", "stress-ng"]],
