    justification = "Broad Podman pruning is blocked for agents.",
    match = ["podman system prune", "podman image prune", "podman volume prune"],
    not_match = ["podman system df", "podman image ls"],
)

rtk_prefix_rule(
    pattern = ["rtk", "podman", ["system", "image", "container", "network", "volume"], "prune"],
