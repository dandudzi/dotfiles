        "id": "459e7ae7-bb57-4ade-b366-4577e45b4f22",
        "type": "custom-command",
        "commandPath": "npx -y ccusage@latest blocks --active --json 2>/dev/null | node -e \"process.stdin.resume();const c=[];process.stdin.on('data',d=>c.push(d));process.stdin.on('end',()=>{try{const d=JSON.parse(c.join(''));const b=d.blocks[0];if(!b){process.stdout.write('no block');return;}const limit=1000000;const pct=Math.min(100,Math.round(b.totalTokens/limit*100));const color=pct>=80?'\\x1b[91m':pct>=50?'\\x1b[33m':'\\x1b[97m';const reset='\\x1b[0m';const minsLeft=Math.max(0,Math.round((new Date(b.endTime)-Date.now())/60000));const timeStr=minsLeft>=60?(Math.floor(minsLeft/60)+'h '+(minsLeft%60)+'m'):minsLeft+'m';process.stdout.write(color+'󱙺 '+pct+'%'+reset+' | '+color+'⏱ '+timeStr+reset);}catch(e){process.stdout.write('err');}});\"",
        "preserveColors": true,
        "timeout": 5000
      },
