{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__plugin_playwright_*",
      "mcp__plugin_claude-mem_*",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(tail:*)",
      "Skill(code-search)",
      "Bash(open:*)",
      "Bash(/usr/bin/open:*)",
      "Bash(node:*)",
      "Bash(unzip:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "WebFetch(domain:example.com)",
      "Bash(*bitwarden*)",
      "Bash(bw:*)",
      "Bash(cat */.env*)",
      "Bash(cat ~/.aws*)",
      "Bash(cat ~/.ssh*)",
      "Bash(grep * ~/.ssh*)",
      "Bash(grep * ~/.aws*)",
      "Bash(chmod 777:*)",
      "Bash(curl *|* bash*)",
      "Bash(curl *|* sh*)",
      "Bash(docker push*)",
      "Bash(git clean -f:*)",
      "Bash(git commit *--no-gpg-sign*)",
      "Bash(git commit *--no-verify*)",
      "Bash(git push --force:*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push *)",
      "Bash(git reset --hard:*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl delete*)",
      "Bash(npm publish*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf*)",
      "Bash(sudo *--force*)",
      "Bash(sudo *-f*)",
      "Bash(sudo:*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(wget *|* bash*)",
      "Bash(wget *|* sh*)",
      "Bash(wget*|*sh:*)",
      "Read(.env.*)",
      "Read(~/.aws/*)",
      "Read(~/.config/gcloud/*)",
      "Read(~/.ssh/*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/jcodemunch-reindex.sh session-start"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your input\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "fitness-track -p"
          },
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude completed the task\" with title \"Claude Code\" sound name \"Glass\"'"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/jcodemunch-reindex.sh stop"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/daniel/.local/bin/dcg"
          },
          {
            "type": "command",
            "command": "dippy"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/daniel/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'L=$(npx -y ccstatusline@latest 2>/dev/null);J=$(bash ~/.claude/hooks/jcodemunch-statusline.sh); [ -n \"$J\" ] && echo \"$L\n$J\" || echo \"$L\"'",
    "padding": 0
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-mermaid@claude-mermaid": true,
    "skill-creator@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true
  },
  "effortLevel": "high",
  "voiceEnabled": true
}
