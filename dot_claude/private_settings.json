{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__plugin_playwright_*",
      "mcp__plugin_claude-mem_*",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(tail:*)",
      "Skill(code-search)",
      "Bash(open:*)",
      "Bash(/usr/bin/open:*)",
      "Bash(node:*)",
      "Bash(unzip:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "WebFetch(domain:example.com)",
      "Bash(*bitwarden*)",
      "Bash(bw:*)",
      "Bash(cat */.env*)",
      "Bash(cat ~/.aws*)",
      "Bash(cat ~/.ssh*)",
      "Bash(grep * ~/.ssh*)",
      "Bash(grep * ~/.aws*)",
      "Bash(chmod 777:*)",
      "Bash(curl *|* bash*)",
      "Bash(curl *|* sh*)",
      "Bash(docker push*)",
      "Bash(git clean -f:*)",
      "Bash(git commit *--no-gpg-sign*)",
      "Bash(git commit *--no-verify*)",
      "Bash(git push --force:*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push *)",
      "Bash(git reset --hard:*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl delete*)",
      "Bash(npm publish*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf*)",
      "Bash(sudo *--force*)",
      "Bash(sudo *-f*)",
      "Bash(sudo:*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(wget *|* bash*)",
      "Bash(wget *|* sh*)",
      "Bash(wget*|*sh:*)",
      "Read(.env.*)",
      "Read(~/.aws/*)",
      "Read(~/.config/gcloud/*)",
      "Read(~/.ssh/*)"
    ],
    "defaultMode": "default"
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your input\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "fitness-track -p"
          },
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude completed the task\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/daniel/.local/bin/dcg"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/daniel/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-mermaid@claude-mermaid": true
  },
  "sandbox": {
    "enabled": true
  }
}
