{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_SPAWN_BACKEND": "tmux",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_COST_WARNINGS": "1"
  },
  "permissions": {
    "allow": [
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__plugin_playwright_*",
      "mcp__plugin_claude-mem_*",
      "mcp__plugin_context-mode_*",
      "mcp__exa__*",
      "mcp__claude_ai_exa__*",
      "mcp__claude_ai_Excalidraw__*",
      "mcp__claude_ai_excalidraw_mcp__*",
      "mcp__jcodemunch__get_symbol",
      "mcp__jcodemunch__get_symbols",
      "mcp__jcodemunch__search_symbols",
      "mcp__jcodemunch__search_text",
      "mcp__jcodemunch__get_file_content",
      "mcp__jcodemunch__get_file_outline",
      "mcp__jcodemunch__get_file_tree",
      "mcp__jcodemunch__get_repo_outline",
      "mcp__jcodemunch__index_folder",
      "mcp__jcodemunch__index_repo",
      "mcp__jcodemunch__invalidate_cache",
      "mcp__jcodemunch__list_repos",
      "mcp__jcodemunch__find_importers",
      "mcp__jcodemunch__find_references",
      "mcp__jdocmunch__index_local",
      "mcp__jdocmunch__index_repo",
      "mcp__jdocmunch__list_repos",
      "mcp__jdocmunch__get_toc",
      "mcp__jdocmunch__get_toc_tree",
      "mcp__jdocmunch__get_document_outline",
      "mcp__jdocmunch__search_sections",
      "mcp__jdocmunch__get_section",
      "mcp__jdocmunch__get_sections",
      "mcp__jdocmunch__delete_index",
      "Bash(rtk:*)",
      "Skill(superpowers:*)",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(tail:*)",
      "Skill(code-search)",
      "Bash(open:*)",
      "Bash(/usr/bin/open:*)",
      "Bash(node:*)",
      "Bash(unzip:*)",
      "Bash(echo:*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)"
    ],
    "deny": [
      "Bash(rtk init*)",
      "Bash(rtk proxy*)",
      "WebFetch(domain:example.com)",
      "Bash(*bitwarden*)",
      "Bash(bw:*)",
      "Bash(cat */.env*)",
      "Bash(cat ~/.aws*)",
      "Bash(cat ~/.ssh*)",
      "Bash(grep * ~/.ssh*)",
      "Bash(grep * ~/.aws*)",
      "Bash(chmod 777:*)",
      "Bash(curl *|* bash*)",
      "Bash(curl *|* sh*)",
      "Bash(docker push*)",
      "Bash(git clean -f:*)",
      "Bash(git commit *--no-gpg-sign*)",
      "Bash(git commit *--no-verify*)",
      "Bash(git push --force:*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push *)",
      "Bash(git reset --hard:*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl delete*)",
      "Bash(npm publish*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf*)",
      "Bash(sudo *--force*)",
      "Bash(sudo *-f*)",
      "Bash(sudo:*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(wget *|* bash*)",
      "Bash(wget *|* sh*)",
      "Bash(wget*|*sh:*)",
      "Read(.env.*)",
      "Read(~/.aws/*)",
      "Read(~/.config/gcloud/*)",
      "Read(~/.ssh/*)",
      "Read(~/.gnupg/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.npm/**)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Read(~/Library/Keychains/**)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/jmunch-session-start.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/context-mode-session-start.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/plugin-drift-check.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your input\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "fitness-track -p"
          },
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude completed the task\" with title \"Claude Code\" sound name \"Glass\"'"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/jcodemunch-reindex.sh stop"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "uvx jcodemunch-mcp hook-event create"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/jmunch-session-gate.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh pre"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/unified-read-router.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/unified-bash-router.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/agent-gate-strict.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/webfetch-block.sh"
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/websearch-block.sh"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/grep-observe.sh"
          }
        ]
      },
      {
        "matcher": "mcp__exa__*|mcp__context7__*|mcp__claude_ai_exa__*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/mcp-observe.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__jcodemunch__index_folder",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/jmunch-sentinel-writer.sh"
          }
        ]
      },
      {
        "matcher": "mcp__jdocmunch__index_local",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/jmunch-sentinel-writer.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/reindex-after-commit.sh"
          }
        ]
      },
      {
        "matcher": "mcp__jdocmunch__*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/track-genuine-savings.sh"
          }
        ]
      },
      {
        "matcher": "mcp__jcodemunch__*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/track-genuine-savings.sh"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_context-mode_context-mode__*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/track-genuine-savings.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Edit|Write|Agent|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh post"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-mermaid@claude-mermaid": false,
    "skill-creator@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context-mode@context-mode": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      },
      "autoUpdate": true
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      },
      "autoUpdate": true
    }
  },
  "sandbox": {
    "enabled": false
  },
  "effortLevel": "medium",
  "voiceEnabled": false,
  "autoMemoryEnabled": false,
  "autoCompact": {
    "customInstructions": "Preserve all file paths, function names, error messages, debugging steps, and architectural decisions."
  },
  "teammateMode": "tmux",
  "gattributiong": {
    "commit": "",
    "pr": ""
  }
}
