{
  "permissions": {
    "allow": [
      "Bash(greppy:*)"
    ],
    "deny": [
      "Glob",
      "Grep",
      "Bash(*bitwarden*)",
      "Bash(bw:*)",
      "Bash(cat */.env:*)",
      "Bash(cat ~/.aws:*)",
      "Bash(cat ~/.ssh:*)",
      "Bash(chmod 777:*)",
      "Bash(curl *|* bash*)",
      "Bash(curl *|* sh*)",
      "Bash(docker push*)",
      "Bash(git clean -f:*)",
      "Bash(git commit *--no-gpg-sign*)",
      "Bash(git commit *--no-verify*)",
      "Bash(git push --force:*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard:*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl delete*)",
      "Bash(npm publish*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf*)",
      "Bash(sudo *--force*)",
      "Bash(sudo *-f*)",
      "Bash(sudo:*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(wget *|* bash*)",
      "Bash(wget *|* sh*)",
      "Bash(wget*|*sh:*)",
      "Read(.env.*)",
      "Read(~/.aws/*)",
      "Read(~/.config/gcloud/*)",
      "Read(~/.ssh/*)",
      "Task(Explore)"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs your input\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "fitness-track -p"
          },
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude completed the task\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/daniel/.local/bin/dcg"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "printf '%s | %s' \"$(ccline)\" \"$(fitness-track statusline)\" ",
    "padding": 0
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "security-guidance@claude-code-plugins": true,
    "playground@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "vtsls@claude-code-lsps": true
  }
}
